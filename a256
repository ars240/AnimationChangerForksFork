    for _, cat in ipairs(categoryConfig) do state.Toggles[cat.name] = toggleWidgets[cat.name].value end
    for i, drop in ipairs(dropdowns) do state.Selections[drop.baseName] = drop.selectedIndex end
    return state
end

local function applyStateData(state)
    if not state then return end
    if state.Keybind then TOGGLE_KEYCODE = state.Keybind end
    for _, cat in ipairs(categoryConfig) do
        if state.Toggles and state.Toggles[cat.name] ~= nil then
            toggleWidgets[cat.name].value = state.Toggles[cat.name]
            enabledCategories[cat.name] = toggleWidgets[cat.name].value
        end
    end
    for fn, _ in pairs(activeSpoofs) do activeSpoofs[fn] = nil end
    for i, drop in ipairs(dropdowns) do
        if state.Selections and state.Selections[drop.baseName] then
            drop.selectedIndex = state.Selections[drop.baseName]
            local opt = drop.optionsData[drop.selectedIndex]
            if opt then
                for fn, ids in pairs(opt.foldersData) do activeSpoofs[fn] = ids end
            end
        else
            drop.selectedIndex = nil
        end
    end
    applyActiveAnimations()
end

