                            end
                            
                            -- Load (Yeşil)
                            if mx >= row.loadBtn.bg.Position.X and mx < row.loadBtn.bg.Position.X + row.loadBtn.bg.Size.X and
                               my >= row.loadBtn.bg.Position.Y and my < row.loadBtn.bg.Position.Y + row.loadBtn.bg.Size.Y then
                                applyStateData(globalConfigsList[i])
                                updateContentLayout()
                                break
                            end
                            -- Update (Turuncu)
                            if mx >= row.updateBtn.bg.Position.X and mx < row.updateBtn.bg.Position.X + row.updateBtn.bg.Size.X and
                               my >= row.updateBtn.bg.Position.Y and my < row.updateBtn.bg.Position.Y + row.updateBtn.bg.Size.Y then
                                globalConfigsList[i] = captureCurrentStateData(globalConfigsList[i].Name)
                                saveAllConfigsToFile()
                                break
                            end
                            -- Delete (Kırmızı)
                            if mx >= row.deleteBtn.bg.Position.X and mx < row.deleteBtn.bg.Position.X + row.deleteBtn.bg.Size.X and
                               my >= row.deleteBtn.bg.Position.Y and my < row.deleteBtn.bg.Position.Y + row.deleteBtn.bg.Size.Y then
                                table.remove(globalConfigsList, i)
                                saveAllConfigsToFile()
                                updateContentLayout()
                                break
                            end
                        end
                    end
                    
                    if not clickedInsideDropdown and activeMenuIndex then
                        local menuX = menuContent.Position.X
                        local menuY = menuContent.Position.Y
                        local targetDrop = dropdowns[activeMenuIndex]
                        
                        for j = 1, #targetDrop.optionsData do
                            local colIndex = math.floor((j - 1) / SUB_MENU_MAX_ROWS)
                            local rowIndex = (j - 1) % SUB_MENU_MAX_ROWS
                            
                            local cellLeft = menuX + (colIndex * SUB_MENU_COL_WIDTH)
                            local cellRight = cellLeft + SUB_MENU_COL_WIDTH
                            local cellTop = menuY + 12 + (rowIndex * (fontSize + rowSpacing)) - (rowSpacing/2)
                            local cellBottom = cellTop + fontSize + rowSpacing
                            
                            if mx >= cellLeft and mx < cellRight and my >= cellTop and my < cellBottom then
                                targetDrop.selectedIndex = j
                                local catName = targetDrop.baseName
                                if enabledCategories[catName] then
                                    local selectedFolders = targetDrop.optionsData[j].foldersData
                                    for _, fName in ipairs(targetDrop.governedFolders) do activeSpoofs[fName] = nil end
                                    for fName, idsList in pairs(selectedFolders) do activeSpoofs[fName] = idsList end
                                    shouldUpdate = true
                                end
                                updateContentLayout()
                                break
                            end
                        end
                    end
                end
            end
        else
            clickDebounce = false
        end

        if isWaitingForKey then
            for vk = 0x01, 0xFE do
                if iskeypressed(vk) then
                    if isMouseButton(vk) then
                        keybindToggle.value.Text = "no mouse"
                        keybindToggle.value.Color = Color3.fromRGB(255, 0, 0)
                        task.wait(0.3)
                        keybindToggle.value.Text = "press key..."
                        keybindToggle.value.Color = Color3.fromRGB(255, 255, 0)
                        break
                    elseif vk ~= 0x1B then
                        TOGGLE_KEYCODE = vk
                        isWaitingForKey = false
                        keybindToggle.isWaiting = false
                        keybindToggle.value.Text = getKeyName(vk)
                        keybindToggle.value.Color = Color3.fromRGB(0, 255, 255)
                        updateContentLayout()
                        break
                    end
                end
            end
        end

        if dragging then
            if not ismouse1pressed() then
                dragging = false
            else
                local delta = Vector2.new(mx - dragStart.X, my - dragStart.Y)
                local newX = windowStartPos.X + delta.X
                local newY = windowStartPos.Y + delta.Y

                titleBar.Position = Vector2.new(newX, newY)
                local baseY = newY + titleHeight/2 - fontSize/2
                title1.Position = Vector2.new(newX + leftPadding, baseY)
                updateContentLayout()
            end
        end

        if activeMenuIndex and not dragging then
            local menuX = menuContent.Position.X
            local menuY = menuContent.Position.Y
            local targetDrop = dropdowns[activeMenuIndex]

            for j, drawing in ipairs(targetDrop.optionDrawings) do
                local colIndex = math.floor((j - 1) / SUB_MENU_MAX_ROWS)
                local rowIndex = (j - 1) % SUB_MENU_MAX_ROWS
                
                local cellLeft = menuX + (colIndex * SUB_MENU_COL_WIDTH)
                local cellRight = cellLeft + SUB_MENU_COL_WIDTH
                local cellTop = menuY + 12 + (rowIndex * (fontSize + rowSpacing)) - (rowSpacing/2)
                local cellBottom = cellTop + fontSize + rowSpacing
                
                local isHovering = (mx >= cellLeft and mx < cellRight and my >= cellTop and my < cellBottom)
                local isSelected = (j == targetDrop.selectedIndex)

                if isHovering or isSelected then
                    if drawing.Transparency ~= 1.0 or drawing.Text ~= "> " .. targetDrop.optionsData[j].name then
                        drawing.Text = "> " .. targetDrop.optionsData[j].name
                        drawing.Transparency = 1.0
                    end
                else
                    if drawing.Transparency ~= 0.7 or drawing.Text ~= targetDrop.optionsData[j].name then
                        drawing.Text = targetDrop.optionsData[j].name
                        drawing.Transparency = 0.7
                    end
                end
            end
        end

        task.wait()
    end
end)

while true do task.wait() end
