local function captureCurrentStateData(nameStr)
    local state = {
        Name = nameStr,
        Toggles = {},
        Selections = {},
        Keybind = TOGGLE_KEYCODE
    }
    for _, cat in ipairs(categoryConfig) do
        state.Toggles[cat.name] = enabledCategories[cat.name]
    end
    for i, drop in ipairs(dropdowns) do
        state.Selections[drop.baseName] = drop.selectedIndex
    end
    return state
end

local function applyStateData(state)
    if not state then return end
    if state.Keybind then TOGGLE_KEYCODE = state.Keybind end
    
    for _, cat in ipairs(categoryConfig) do
        if state.Toggles and state.Toggles[cat.name] ~= nil then
            enabledCategories[cat.name] = state.Toggles[cat.name]
            local toggle = toggleWidgets[cat.name]
            if toggle then
                toggle.value = enabledCategories[cat.name]
                toggle.enabled.Text = toggle.value and "ON" or "OFF"
                toggle.enabled.Color = toggle.value and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
            end
        end
    end
    
    for folderName, _ in pairs(activeSpoofs) do activeSpoofs[folderName] = nil end
    
    for i, drop in ipairs(dropdowns) do
        if state.Selections and state.Selections[drop.baseName] then
            drop.selectedIndex = state.Selections[drop.baseName]
            local selectedPack = drop.optionsData[drop.selectedIndex]
            if selectedPack and enabledCategories[drop.baseName] then
                for fName, idsList in pairs(selectedPack.foldersData) do
                    activeSpoofs[fName] = idsList
                end
            end
        else
            drop.selectedIndex = nil
        end
    end
    shouldUpdate = true
end

updateContentLayout()

local function handleToggleClick(catName)
    local toggle = toggleWidgets[catName]
    if not toggle then return end
    
    toggle.value = not toggle.value
    enabledCategories[catName] = toggle.value
    toggle.enabled.Text = toggle.value and "ON" or "OFF"
    toggle.enabled.Color = toggle.value and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
    
    if not toggle.value then
        for _, cat in ipairs(categoryConfig) do
            if cat.name == catName then
                for _, fName in ipairs(cat.folders) do activeSpoofs[fName] = nil end
                break
            end
        end
    else
        for i, cat in ipairs(categoryConfig) do
            if cat.name == catName then
                local drop = dropdowns[i]
                if drop and drop.selectedIndex then
                    local selectedPack = drop.optionsData[drop.selectedIndex]
                    if selectedPack then
                        for _, fName in ipairs(cat.folders) do activeSpoofs[fName] = nil end
                        for fName, idsList in pairs(selectedPack.foldersData) do activeSpoofs[fName] = idsList end
                    end
                end
                break
            end
        end
    end
    shouldUpdate = true
end

