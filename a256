    addOut.Position=addBg.Position; addOut.Size=addBg.Size; addOut.Color=C.C_MUTED; addOut.Transparency=0.3*globalAlpha; addOut.Visible=true
    
    addTxt.Size=FS; addTxt.Position=Vector2.new(rox+RW/2, ry+(RH+6)/2-FS/2); addTxt.Center=true
    if #globalConfigsList >= MAX_CONFIGS then
        addTxt.Text="MAX PROFILES ("..MAX_CONFIGS..")"; addTxt.Color=C.C_MUTED; addTxt.Transparency=0.8*globalAlpha
    else
        addTxt.Text="+  NEW PROFILE ("..#globalConfigsList.."/"..MAX_CONFIGS..")"; addTxt.Color=C.C_ACCENT; addTxt.Transparency=1.0*globalAlpha
    end
    addTxt.Visible=true
    ry = ry + RH + 24

    local totalProfs = #globalConfigsList
    if totalProfs <= VISIBLE_PROFILES then scrollOffset = 0 end
    if scrollOffset > math.max(0, totalProfs - VISIBLE_PROFILES) then scrollOffset = math.max(0, totalProfs - VISIBLE_PROFILES) end

    local sbY = ry
    local sbH = VISIBLE_PROFILES * (PRH + 8) - 8
    local sbX = rox + RW - LP - 10
    local sbW = 10
    
    for i=1,VISIBLE_PROFILES do
        local r = profileRows[i]
        local realIndex = i + scrollOffset
        local conf = globalConfigsList[realIndex]
        if conf then
            r.bg.Position=Vector2.new(rox+LP,ry); r.bg.Size=Vector2.new(RW-LP*2-20,PRH)
            r.bg.Color=C.C_ROW; r.bg.Transparency=0.9*globalAlpha; r.bg.Visible=true
            
            r.title.Text=conf.Name or ("Profile "..realIndex); r.title.Size=FS; r.title.Position=Vector2.new(rox+LP+12, ry+PRH/2-FS/2)
            r.title.Color=C.C_TEXT; r.title.Transparency=0.9*globalAlpha; r.title.Visible=true

            local bw, bh = 50, 28
            local by = ry + PRH/2 - bh/2
            local ex = rox + RW - LP - 28 
            local gap = 8 
            
            -- DELETE
            bounds.del[i] = {ex-bw, by, bw, bh, realIndex}
            r.delBg.Position=Vector2.new(ex-bw,by); r.delBg.Size=Vector2.new(bw,bh)
            r.delBg.Color=inB(bounds.del[i],mx,my) and hoverCol(C.C_RED) or C.C_RED; r.delBg.Transparency=1.0*globalAlpha; r.delBg.Visible=true
            r.delOut.Position=r.delBg.Position; r.delOut.Size=r.delBg.Size; r.delOut.Color=C.C_TITLE; r.delOut.Transparency=0.6*globalAlpha; r.delOut.Visible=true
            r.delT.Text="Del"; r.delT.Size=FS-1; r.delT.Position=Vector2.new(ex-bw+bw/2, by+bh/2-(FS-1)/2+1); r.delT.Center=true
            r.delT.Color=C.C_TITLE; r.delT.Transparency=1.0*globalAlpha; r.delT.Visible=true
            
            -- UPDATE
            bounds.upd[i] = {ex-bw*2-gap, by, bw, bh, realIndex}
            r.updBg.Position=Vector2.new(ex-bw*2-gap,by); r.updBg.Size=Vector2.new(bw,bh)
            r.updBg.Color=inB(bounds.upd[i],mx,my) and hoverCol(C.C_ORANGE) or C.C_ORANGE; r.updBg.Transparency=1.0*globalAlpha; r.updBg.Visible=true
            r.updOut.Position=r.updBg.Position; r.updOut.Size=r.updBg.Size; r.updOut.Color=C.C_TITLE; r.updOut.Transparency=0.6*globalAlpha; r.updOut.Visible=true
            r.updT.Text="Upd"; r.updT.Size=FS-1; r.updT.Position=Vector2.new(ex-bw*2-gap+bw/2, by+bh/2-(FS-1)/2+1); r.updT.Center=true
            r.updT.Color=C.C_TITLE; r.updT.Transparency=1.0*globalAlpha; r.updT.Visible=true
            
            -- LOAD
            bounds.load[i] = {ex-bw*3-gap*2, by, bw, bh, realIndex}
            r.loadBg.Position=Vector2.new(ex-bw*3-gap*2,by); r.loadBg.Size=Vector2.new(bw,bh)
            r.loadBg.Color=inB(bounds.load[i],mx,my) and hoverCol(C.C_GREEN) or C.C_GREEN; r.loadBg.Transparency=1.0*globalAlpha; r.loadBg.Visible=true
            r.loadOut.Position=r.loadBg.Position; r.loadOut.Size=r.loadBg.Size; r.loadOut.Color=C.C_TITLE; r.loadOut.Transparency=0.6*globalAlpha; r.loadOut.Visible=true
            r.loadT.Text="Load"; r.loadT.Size=FS-1; r.loadT.Position=Vector2.new(ex-bw*3-gap*2+bw/2, by+bh/2-(FS-1)/2+1); r.loadT.Center=true
            r.loadT.Color=C.C_TITLE; r.loadT.Transparency=1.0*globalAlpha; r.loadT.Visible=true

            ry = ry + PRH + 8
        else
            r.bg.Visible=false; r.title.Visible=false
            r.loadBg.Visible=false; r.loadOut.Visible=false; r.loadT.Visible=false
            r.updBg.Visible=false;  r.updOut.Visible=false; r.updT.Visible=false
            r.delBg.Visible=false;  r.delOut.Visible=false; r.delT.Visible=false
            bounds.load[i]={0,0,0,0}; bounds.upd[i]={0,0,0,0}; bounds.del[i]={0,0,0,0}
        end
    end

    scrollTrack.Position=Vector2.new(sbX,sbY); scrollTrack.Size=Vector2.new(sbW,sbH)
    scrollTrack.Color=C.C_ROW; scrollTrack.Transparency=0.6*globalAlpha; scrollTrack.Visible=true
    
    if totalProfs > VISIBLE_PROFILES then
        local pct = VISIBLE_PROFILES / totalProfs
        local thumbH = math.max(30, sbH * pct)
        local maxOffset = totalProfs - VISIBLE_PROFILES
        if not draggingScroll then visualScrollPct = scrollOffset / maxOffset end
        local thumbY = sbY + visualScrollPct * (sbH - thumbH)
        scrollThumb.Position=Vector2.new(sbX,thumbY); scrollThumb.Size=Vector2.new(sbW,thumbH)
    else
        scrollThumb.Position=Vector2.new(sbX,sbY); scrollThumb.Size=Vector2.new(sbW,sbH)
    end
    scrollThumb.Color=C.C_MUTED; scrollThumb.Transparency=1.0*globalAlpha; scrollThumb.Visible=true
    bounds.scroll = {sbX-8, sbY-8, sbW+16, sbH+16}

    local rightH = math.max(ry, sbY + sbH + 12) - bodyY
    local maxH = math.max(leftBg.Size.Y, rightH)
    leftBg.Size  = Vector2.new(LW, maxH)
    rightBg.Size = Vector2.new(RW, maxH)

    -- SUBMENU OR SETTINGS
    if activeMenuIndex then
        local isSettings = (activeMenuIndex == "settings")
        local opts = {}
        if isSettings then
            for _, th in ipairs(ThemeOrder) do table.insert(opts, {name = th .. " Theme", isTheme = th}) end
            local notifLabel = "Notifications"
            table.insert(opts, {name = notifLabel, isNotifToggle = true})
        else
            opts = dropdowns[activeMenuIndex].optionsData
        end

        local total = #opts
        if total > 0 then
            local cols = math.ceil(total/SUB_ROWS)
            local rows = math.min(total, SUB_ROWS)
            
            local itemH = FS + 12
            local itemGap = 6
            local rowHeight = itemH + itemGap
            
            local mh = 16 + rows * rowHeight - itemGap + 16 
            local mw = isSettings and 240 or (cols * SUB_COL_W + 16)
            local smx = tx + W + 12
            local smy = ty + TH

            subBg.Position=Vector2.new(smx,smy); subBg.Size=Vector2.new(mw,mh)
            subBg.Color=C.C_BG; subBg.Transparency=0.98*globalAlpha; subBg.Visible=true
            subOutline.Position=subBg.Position; subOutline.Size=subBg.Size; subOutline.Color=C.C_ACCENT; subOutline.Transparency=0.5*globalAlpha; subOutline.Visible=true

            if prevActiveMenuIndex ~= activeMenuIndex then
                clearSubs()
                for idx,opt in ipairs(opts) do
                    local bg = mkS()
                    pcall(function() bg.Corner = 4 end)
                    table.insert(subBgs, bg)
                    
                    local out = mkOut()
                    pcall(function() out.Corner = 4 end)
                    table.insert(subOuts, out)

                    if isSettings then
                        local opt = opts[idx]
                        if opt and opt.isTheme then
                            local ti=mkS()
                            ti.Size=Vector2.new(13,13)
                            ti.Color=Themes[opt.isTheme].C_ACCENT; ti.Transparency=1.0*globalAlpha; ti.Visible=true
                            pcall(function() ti.Corner=2 end)
                            table.insert(subThemeIcons, ti)
                        elseif opt and opt.isNotifToggle then
                            -- checkbox square
                            local cb = mkOut()
                            cb.Size=Vector2.new(13,13)
                            cb.Color=C.C_MUTED; cb.Transparency=0.8*globalAlpha; cb.Visible=true
                            pcall(function() cb.Corner=3 end)
                            -- inner fill
                            local cbFill = mkS()
                            cbFill.Size=Vector2.new(9,9)
                            cbFill.Color=C.C_ACCENT; cbFill.Visible=false
                            pcall(function() cbFill.Corner=2 end)
                            table.insert(subThemeIcons, {border=cb, fill=cbFill, isCheckbox=true})
                        else
                            table.insert(subThemeIcons, false)
                        end
                    end
                    
                    local lbl=mkT(); lbl.Text=opt.name; lbl.Size=FS
                    table.insert(subOptLabels,lbl)
                    table.insert(bounds.subs,{0,0,0,0,opt,idx})
                end
                prevActiveMenuIndex = activeMenuIndex
            end

            for i, lbl in ipairs(subOptLabels) do
                local sb = bounds.subs[i]
                if sb then
                    local opt = sb[5]
                    local optIdx = sb[6]
                    
                    local col=math.floor((optIdx-1)/SUB_ROWS)
                    local row=(optIdx-1)%SUB_ROWS
                    
                    local lx=smx+16+col*(isSettings and 240 or SUB_COL_W)
                    local ly=smy+16+row*rowHeight
                    local itemW = isSettings and 200 or (SUB_COL_W - 16)
                    
                    sb[1] = lx
                    sb[2] = ly
                    sb[3] = itemW
                    sb[4] = itemH

                    local hovered = inB(sb,mx,my)
                    
                    local bg = subBgs[i]
                    local out = subOuts[i]
                    
                    bg.Position = Vector2.new(sb[1], sb[2])
                    bg.Size = Vector2.new(sb[3], sb[4])
                    bg.Color = hovered and C.C_ROW or C.C_TITLE
                    bg.Transparency = 0.6 * globalAlpha
                    bg.Visible = true
                    
                    out.Position = bg.Position
                    out.Size = bg.Size
                    out.Color = hovered and C.C_ACCENT or C.C_MUTED
                    out.Transparency = hovered and (0.8 * globalAlpha) or (0.2 * globalAlpha)
                    out.Visible = true
                    
                    if isSettings then
                        local ti = subThemeIcons[i]
                        if ti and ti ~= false then
                            if ti.isCheckbox then
                                -- draw checkbox border
                                ti.border.Position=Vector2.new(sb[1]+8, sb[2]+sb[4]/2-6)
                                ti.border.Color = notificationsEnabled and C.C_ACCENT or C.C_MUTED
                                ti.border.Transparency=0.9*globalAlpha; ti.border.Visible=true
                                -- draw inner tick fill when ON
                                ti.fill.Position=Vector2.new(sb[1]+10, sb[2]+sb[4]/2-4)
                                ti.fill.Color = C.C_ACCENT
                                ti.fill.Transparency = notificationsEnabled and (1.0*globalAlpha) or 0
                                ti.fill.Visible = notificationsEnabled
                            else
                                ti.Position=Vector2.new(sb[1]+8, sb[2]+sb[4]/2-6)
                                ti.Transparency=1.0*globalAlpha
                            end
                        end
                    end
                    
                    lbl.Position=Vector2.new(isSettings and (sb[1]+28) or (sb[1]+10), sb[2]+sb[4]/2 - FS/2)
                    if isSettings then
                        local opt = sb[5]
                        if opt and opt.isNotifToggle then
                            lbl.Color = hovered and C.C_ACCENT or C.C_TEXT
                        elseif opt and opt.isTheme then
                            lbl.Color = hovered and Themes[opt.isTheme].C_ACCENT or Themes[opt.isTheme].C_TEXT
                        else
                            lbl.Color = hovered and C.C_ACCENT or C.C_TEXT
                        end
                    else
                        lbl.Color = hovered and C.C_ACCENT or C.C_TEXT
                    end
                    lbl.Transparency=0.9*globalAlpha; lbl.Visible=true
                end
            end
        else
            subBg.Visible=false; subOutline.Visible=false; clearSubs(); prevActiveMenuIndex = -1
        end
    else
        subBg.Visible=false; subOutline.Visible=false; clearSubs(); prevActiveMenuIndex = -1
    end
end

-- =====================================================
-- INPUT HANDLING
-- =====================================================
local dragging=false; local dragStart=nil; local windowStartPos=nil
local draggingScroll=false; local clickDebounce=false

local function handleScrollInput(my)
    local sb = bounds.scroll
    if sb and sb[4] > 0 then
        local totalProfs = #globalConfigsList
        local maxOffset = totalProfs - VISIBLE_PROFILES
        if maxOffset > 0 then
            local relY = my - sb[2]
            local pct = math.clamp(relY / sb[4], 0, 1)
            visualScrollPct = pct
            scrollOffset = math.floor(pct * maxOffset + 0.5)
        end
    end
end

task.spawn(function()
    while true do
        local mx, my = mouse.X, mouse.Y
        local mb = ismouse1pressed()

        if globalAlpha > 0 then
            if mb and not dragging and not draggingScroll and not isWaitingForKey then
                if inB(bounds.title,mx,my) and not inB(bounds.settings,mx,my) and not inB(bounds.reset,mx,my) then
                    dragging=true
                    dragStart=Vector2.new(mx,my)
                    windowStartPos=Vector2.new(startX,startY)
                elseif inB(bounds.scroll, mx, my) then
                    draggingScroll=true
                    handleScrollInput(my)
                end
            end

            if not mb and clickDebounce and not dragging and not draggingScroll then
                if inB(bounds.settings, mx, my) then
                    if activeMenuIndex == "settings" then activeMenuIndex = nil else activeMenuIndex = "settings" end
                end
                
                if inB(bounds.reset, mx, my) then
                    for i, cat in ipairs(categoryConfig) do
                        local tw = toggleWidgets[cat.name]
                        tw.selName.Text = ""
                        dropdowns[i].selectedIndex = nil
                    end
                    for fn, _ in pairs(activeSpoofs) do activeSpoofs[fn] = nil end
                    applyActiveAnimations()
                    showNotification("Animations Reset!")
                end

                if inB(bounds.keybind,mx,my) and not isWaitingForKey then
                    isWaitingForKey=true; kbVal.Text="..."; kbVal.Color=C.C_RED
                end

                for i, cat in ipairs(categoryConfig) do
                    local bc = bounds.cats[i]
                    if inB(bc.toggle,mx,my) then
                        local tw = toggleWidgets[cat.name]
                        tw.value = not tw.value
                        enabledCategories[cat.name] = tw.value
                        applyActiveAnimations()
                    elseif inB(bc.drop,mx,my) then
                        if activeMenuIndex==i then activeMenuIndex=nil else activeMenuIndex=i end
                    end
                end

                for _,sb in ipairs(bounds.subs) do
                    if inB(sb,mx,my) then
                        local opt=sb[5]
                        if opt.isNotifToggle then
                            notificationsEnabled = not notificationsEnabled
                            prevActiveMenuIndex = -1  -- force submenu rebuild so checkbox updates
                        elseif opt.isTheme then
                            C = Themes[opt.isTheme] or Themes.Navy
                            currentThemeName = opt.isTheme
                            saveTheme()
                            showNotification("Theme Set: " .. opt.isTheme)
                        else
                            local dd=dropdowns[activeMenuIndex]
                            dd.selectedIndex=sb[6]
                            local tw = toggleWidgets[dd.baseName]
                            tw.selName.Text = opt.name
                            for fn,ids in pairs(opt.foldersData) do activeSpoofs[fn]=ids end
                            applyActiveAnimations()
                            showNotification("Applied: "..opt.name)
                        end
                        break
                    end
                end

                if inB(bounds.addBtn,mx,my) then
                    if #globalConfigsList < MAX_CONFIGS then
                        local n="Profile "..( #globalConfigsList+1 )
                        table.insert(globalConfigsList, captureCurrentStateData(n))
                        saveAllConfigsToFile()
                        showNotification("Saved: '"..n.."'")
                        scrollOffset = math.max(0, #globalConfigsList - VISIBLE_PROFILES)
                    end
                end

                for i=1,VISIBLE_PROFILES do
                    if inB(bounds.load[i],mx,my) then
                        local rIdx = bounds.load[i][5]
                        applyStateData(globalConfigsList[rIdx])
                        showNotification("Loaded: '"..globalConfigsList[rIdx].Name.."'")
                        break
                    elseif inB(bounds.upd[i],mx,my) then
                        local rIdx = bounds.upd[i][5]
                        globalConfigsList[rIdx]=captureCurrentStateData(globalConfigsList[rIdx].Name)
                        saveAllConfigsToFile()
                        showNotification("Updated: '"..globalConfigsList[rIdx].Name.."'")
                        break
                    elseif inB(bounds.del[i],mx,my) then
                        local rIdx = bounds.del[i][5]
                        table.remove(globalConfigsList,rIdx); saveAllConfigsToFile()
                        break
                    end
                end
                clickDebounce=false
            elseif mb and not clickDebounce and not dragging and not draggingScroll then
                clickDebounce=true
            end
        end

        if not mb then dragging=false; draggingScroll=false end
        
        if dragging then
            local d=Vector2.new(mx,my)-dragStart
            local np=windowStartPos+d
            startX=np.X; startY=np.Y
        elseif draggingScroll then
            handleScrollInput(my)
        end

        if isUIVisible and globalAlpha < 1 then
            globalAlpha = math.min(1, globalAlpha + 0.12)
        elseif not isUIVisible and globalAlpha > 0 then
            globalAlpha = math.max(0, globalAlpha - 0.12)
        end

        layout(mx, my)
        task.wait()
    end
end)

task.spawn(function()
    local last=false
    while true do
        if isWaitingForKey then
            for vk=1,254 do
                if iskeypressed(vk) then
                    if vk~=1 and vk~=2 and vk~=4 and vk~=5 and vk~=6 and vk~=8 then
                        TOGGLE_KEYCODE=vk
                        kbVal.Text=getKeyName(TOGGLE_KEYCODE); kbVal.Color=C.C_ACCENT
                        isWaitingForKey=false; break
                    end
                end
            end
        else
            local cur=iskeypressed(TOGGLE_KEYCODE)
            if cur and not last then
                isUIVisible=not isUIVisible
                if not isUIVisible then dragging=false; draggingScroll=false end
            end
            last=cur
        end
        task.wait()
    end
end)

