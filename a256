local function checkKeyboardInputForNaming()
    if not editingProfileIndex then return end
    local prof = globalConfigsList[editingProfileIndex]
    if not prof then return end
    
    if iskeypressed(8) then 
        if not _G.backspaceDebounce then
            _G.backspaceDebounce = true
            if #prof.Name > 0 then
                prof.Name = string.sub(prof.Name, 1, #prof.Name - 1)
                updateContentLayout()
            end
        end
    else
        _G.backspaceDebounce = false
    end
    
    if iskeypressed(13) then
        if #prof.Name == 0 then prof.Name = "Config " .. editingProfileIndex end
        editingProfileIndex = nil
        saveAllConfigsToFile()
        updateContentLayout()
        task.wait(0.2)
        return
    end
    
    if not _G.keyInputDebounce then
        for vk = 0x30, 0x5A do
            if iskeypressed(vk) then
                _G.keyInputDebounce = true
                local char = string.char(vk)
                if not (iskeypressed(0x10)) then char = string.lower(char) end
                prof.Name = prof.Name .. char
                updateContentLayout()
                break
            end
        end
        if iskeypressed(32) then
            _G.keyInputDebounce = true
            prof.Name = prof.Name .. " "
            updateContentLayout()
        end
    else
        local absoluteReleased = true
        for vk = 0x30, 0x5A do if iskeypressed(vk) then absoluteReleased = false end end
        if iskeypressed(32) then absoluteReleased = false end
        if absoluteReleased then _G.keyInputDebounce = false end
    end
end

