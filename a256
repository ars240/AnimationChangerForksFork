local function saveAllConfigsToFile()
    if writefile then
        local success, jsonStr = pcall(function() return HttpService:JSONEncode(globalConfigsList) end)
        if success then writefile(CONFIG_FILE, jsonStr) end
    end
end

local function loadAllConfigsFromFile()
    if isfile and readfile and isfile(CONFIG_FILE) then
        local success, content = pcall(readfile, CONFIG_FILE)
        if success then
            local ok, parsed = pcall(function() return HttpService:JSONDecode(content) end)
            if ok and type(parsed) == "table" then globalConfigsList = parsed end
        end
    end
end

