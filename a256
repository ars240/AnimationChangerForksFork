                    for i = 1, 5 do
                        local row = profileRows[i]
                        if globalConfigsList[i] and row.bg.Visible then
                            if mx >= row.bg.Position.X and mx < row.loadBtn.bg.Position.X - 4 and
                               my >= row.bg.Position.Y and my < row.bg.Position.Y + row.bg.Size.Y then
                                editingProfileIndex = i
                                globalConfigsList[i].Name = ""
                                updateContentLayout()
                                break
                            end
                            
                            if mx >= row.loadBtn.bg.Position.X and mx < row.loadBtn.bg.Position.X + row.loadBtn.bg.Size.X and
                               my >= row.loadBtn.bg.Position.Y and my < row.loadBtn.bg.Position.Y + row.loadBtn.bg.Size.Y then
                                applyStateData(globalConfigsList[i])
                                updateContentLayout()
                                break
                            end
                            if mx >= row.updateBtn.bg.Position.X and mx < row.updateBtn.bg.Position.X + row.updateBtn.bg.Size.X and
                               my >= row.updateBtn.bg.Position.Y and my < row.updateBtn.bg.Position.Y + row.updateBtn.bg.Size.Y then
                                globalConfigsList[i] = captureCurrentStateData(globalConfigsList[i].Name)
                                saveAllConfigsToFile()
                                break
                            end
                            if mx >= row.deleteBtn.bg.Position.X and mx < row.deleteBtn.bg.Position.X + row.deleteBtn.bg.Size.X and
                               my >= row.deleteBtn.bg.Position.Y and my < row.deleteBtn.bg.Position.Y + row.deleteBtn.bg.Size.Y then
                                table.remove(globalConfigsList, i)
                                saveAllConfigsToFile()
                                updateContentLayout()
                                break
                            end
                        end
                    end
                end
                
                if activeMenuIndex then
                    local targetDrop = dropdowns[activeMenuIndex]
                    local menuX = titleBar.Position.X + width + 8
                    local menuY = titleBar.Position.Y + titleHeight
                    
                    local totalItems = #targetDrop.optionsData
                    if totalItems > 0 then
                        local numColumns = math.ceil(totalItems / SUB_MENU_MAX_ROWS)
                        local numRows = math.min(totalItems, SUB_MENU_MAX_ROWS)
                        local totalTextHeight = numRows * fontSize
                        local totalGapsHeight = (numRows - 1) * rowSpacing
                        local menuHeight = 16 + totalTextHeight + totalGapsHeight + 16
                        local menuTotalWidth = numColumns * SUB_MENU_COL_WIDTH
                        
                        if mx >= menuX and mx <= menuX + menuTotalWidth and my >= menuY and my <= menuY + menuHeight then
                            for j, drawing in ipairs(targetDrop.optionDrawings) do
                                local colIndex = math.floor((j - 1) / SUB_MENU_MAX_ROWS)
                                local rowIndex = (j - 1) % SUB_MENU_MAX_ROWS
                                local drawX = menuX + 16 + (colIndex * SUB_MENU_COL_WIDTH)
                                local drawY = menuY + 16 + (rowIndex * (fontSize + rowSpacing))
                                
                                if mx >= drawX and mx <= drawX + SUB_MENU_COL_WIDTH - 10 and my >= drawY and my <= drawY + fontSize then
                                    if targetDrop.selectedIndex == j then
                                        targetDrop.selectedIndex = nil
                                        for _, fName in ipairs(targetDrop.governedFolders) do activeSpoofs[fName] = nil end
                                    else
                                        targetDrop.selectedIndex = j
                                        local selectedPack = targetDrop.optionsData[j]
                                        if enabledCategories[targetDrop.baseName] and selectedPack then
                                            for fName, idsList in pairs(selectedPack.foldersData) do activeSpoofs[fName] = idsList end
                                        end
                                    end
                                    shouldUpdate = true
                                    updateContentLayout()
                                    break
                                end
                            end
                        end
                    end
                end
            end
        else
            clickDebounce = false
        end

        if not ismouse1pressed() and dragging then dragging = false end

        if dragging then
            local delta = Vector2.new(mx, my) - dragStart
            titleBar.Position = windowStartPos + delta
            updateContentLayout()
        end
        task.wait(0.01)
    end
end)

