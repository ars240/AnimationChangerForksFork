            continue
        end

        local insideTitle =
            mx >= titleBar.Position.X and mx <= titleBar.Position.X + titleBar.Size.X and
            my >= titleBar.Position.Y and my <= titleBar.Position.Y + titleBar.Size.Y

        if insideTitle and ismouse1pressed() and not dragging and not isWaitingForKey then
            dragging = true
            dragStart = Vector2.new(mx, my)
            windowStartPos = titleBar.Position
        end

        if ismouse1pressed() then
            if not clickDebounce then
                clickDebounce = true
                
                if not dragging and not isWaitingForKey then
                    local titleX = titleBar.Position.X
                    local titleY = titleBar.Position.Y
                    local startContentY = titleY + titleHeight
                    local checkY = startContentY + 12
                    local clickedInsideDropdown = false
                    
